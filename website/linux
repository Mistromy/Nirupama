#!/bin/bash
set -e

echo "Starting Nirupama installer..."

# 1. Create the directory
mkdir -p ./Nirupama

# If run with sudo, fix the directory ownership immediately so the normal user owns it
if [ -n "$SUDO_USER" ]; then
    chown -R "$SUDO_USER:" ./Nirupama
fi

cd ./Nirupama

# 2. Detect Architecture
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)        BINARY_ARCH="amd64" ;;
    aarch64|arm64) BINARY_ARCH="arm64" ;;
    *)             echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
esac

# 3. Download supervisor
REPO="mistromy/Nirupama"
URL="https://github.com/$REPO/releases/latest/download/supervisor-linux-$BINARY_ARCH"
curl -L -o supervisor "$URL"

# Fix binary ownership and permissions
if [ -n "$SUDO_USER" ]; then
    chown "$SUDO_USER:" supervisor
fi
chmod +x supervisor

echo "Launching supervisor..."

# 4. Execute supervisor (passing down all flags like -y and --key)
./supervisor "$@"